{% doc %}
  @prompt
    An interactive vertical timeline that highlights as the user scrolls
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-timeline-wrapper-{{ ai_gen_id }} {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: {{ block.settings.line_position }}px;
    top: 0;
    bottom: 0;
    width: {{ block.settings.line_width }}px;
    background-color: {{ block.settings.line_color }};
    z-index: 1;
  }

  .ai-timeline-progress-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0%;
    background-color: {{ block.settings.line_active_color }};
    transition: height 0.3s ease;
  }

  .ai-timeline-items-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    padding-left: {{ block.settings.line_position | plus: 40 }}px;
    padding-bottom: {{ block.settings.item_spacing }}px;
    opacity: 0.5;
    transition: opacity 0.5s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    left: {{ block.settings.line_position | minus: block.settings.dot_size | divided_by: 2 }}px;
    top: 0;
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: {{ block.settings.dot_border_width }}px solid {{ block.settings.line_color }};
    transition: all 0.5s ease;
    z-index: 3;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-dot-{{ ai_gen_id }} {
    background-color: {{ block.settings.dot_active_color }};
    border-color: {{ block.settings.line_active_color }};
    transform: scale(1.3);
    box-shadow: 0 0 0 {{ block.settings.dot_glow_size }}px {{ block.settings.dot_active_color }}33;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    border: 1px solid {{ block.settings.card_border_color }};
    transition: all 0.5s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-content-{{ ai_gen_id }} {
    border-color: {{ block.settings.line_active_color }};
    box-shadow: 0 4px 12px {{ block.settings.line_active_color }}22;
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_font_size }}px;
    color: {{ block.settings.date_color }};
    font-weight: 600;
    margin-bottom: 8px;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 700;
    margin: 0 0 12px 0;
    line-height: 1.3;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-timeline-item-{{ ai_gen_id }} {
      padding-left: 50px;
    }

    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-dot-{{ ai_gen_id }} {
      left: {{ 20 | minus: block.settings.dot_size | divided_by: 2 }}px;
    }

    .ai-timeline-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }

    .ai-timeline-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<scroll-timeline-{{ ai_gen_id }} class="ai-timeline-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-wrapper-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}">
      <div class="ai-timeline-progress-{{ ai_gen_id }}"></div>
    </div>

    <div class="ai-timeline-items-{{ ai_gen_id }}">
      {% if block.settings.item_1_enabled %}
        <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
          <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
          <div class="ai-timeline-content-{{ ai_gen_id }}">
            {% if block.settings.item_1_date != blank %}
              <div class="ai-timeline-date-{{ ai_gen_id }}">{{ block.settings.item_1_date }}</div>
            {% endif %}
            {% if block.settings.item_1_title != blank %}
              <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ block.settings.item_1_title }}</h3>
            {% endif %}
            {% if block.settings.item_1_description != blank %}
              <div class="ai-timeline-description-{{ ai_gen_id }}">{{ block.settings.item_1_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.item_2_enabled %}
        <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
          <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
