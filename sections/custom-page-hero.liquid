<link rel="stylesheet" href="{{ 'custom.css' | asset_url }}">
{% style %}
  .custom-hero {
    position: relative;
    display: flex;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  .custom-hero__overlay {
    position: absolute;
    inset: 0;
  }

  .custom-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    text-align: center;
    /* Make this a setting later if needed */
  }

  .hero-buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
{% endstyle %}
<section class="custom-hero" style="
    min-height: {{ section.settings.hero_height }}px;
    background-image: url('{{ section.settings.background_image | image_url: width: 2400 }}');
    justify-content: {{ section.settings.horizontal_alignment }};
    align-items: {{ section.settings.vertical_alignment }};
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    ">
  <div class="custom-hero__overlay" style="
      background: {{ section.settings.overlay_color }};
      opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    ">
  </div>

  <div class="custom-hero__content" style="max-width: {{ section.settings.content_max_width }}px;">
    {% if section.settings.hero_heading != blank %}
      <div class="hero-heading" style="margin-bottom: {{ section.settings.heading_margin_bottom }}px;">
        {{ section.settings.hero_heading }}
      </div>
    {% endif %}

    {% if section.settings.hero_description != blank %}
      <div class="hero-description" style="margin-bottom: {{ section.settings.description_margin_bottom }}px;">
        {{ section.settings.hero_description }}
      </div>
    {% endif %}

    {% if section.settings.left_button_text != blank or section.settings.right_button_text != blank
    %}
      <div class="hero-buttons">
        {% if section.settings.left_button_text != blank %}
          <a href="{{ section.settings.left_button_link }}" class="hero-btn">
            {{ section.settings.left_button_text }}
          </a>
        {% endif %}

        {% if section.settings.right_button_text != blank %}
          <a href="{{ section.settings.right_button_link }}" class="hero-btn hero-btn--secondary">
            {{ section.settings.right_button_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>
{% schema %}
  {
    "name": "Custom Page Hero",
    "settings": [
      {
        "type": "image_picker",
        "id": "background_image",
        "label": "Background Image"
      },
      {
        "type": "range",
        "id": "hero_height",
        "label": "Hero Height",
        "min": 400,
        "max": 1000,
        "step": 20,
        "unit": "px",
        "default": 720
      },
      {
        "type": "range",
        "id": "content_max_width",
        "label": "Content Width",
        "min": 300,
        "max": 1200,
        "step": 20,
        "unit": "px",
        "default": 700
      },
      {
        "type": "select",
        "id": "vertical_alignment",
        "label": "Vertical Alignment",
        "default": "center",
        "options": [
          {
            "value": "flex-start",
            "label": "Top"
          }, {
            "value": "center",
            "label": "Center"
          }, {
            "value": "flex-end",
            "label": "Bottom"
          }
        ]
      }, {
        "type": "select",
        "id": "horizontal_alignment",
        "label": "Horizontal Alignment",
        "default": "center",
        "options": [
          {
            "value": "flex-start",
            "label": "Left"
          }, {
            "value": "center",
            "label": "Center"
          }, {
            "value": "flex-end",
            "label": "Right"
          }
        ]
      }, {
        "type": "range",
        "id": "section_padding_top",
        "label": "Section Padding Top",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "default": 0
      }, {
        "type": "range",
        "id": "section_padding_bottom",
        "label": "Section Padding Bottom",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "default": 0
      }, {
        "type": "richtext",
        "id": "hero_heading",
        "label": "Heading"
      }, {
        "type": "range",
        "id": "heading_margin_bottom",
        "label": "Heading Bottom Margin",
        "min": 0,
        "max": 400,
        "step": 4,
        "unit": "px",
        "default": 24
      }, {
        "type": "richtext",
        "id": "hero_description",
        "label": "Description"
      }, {
        "type": "range",
        "id": "description_margin_bottom",
        "label": "Description Bottom Margin",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "default": 32
      }, {
        "type": "text",
        "id": "left_button_text",
        "label": "Primary Button Label"
      }, {
        "type": "url",
        "id": "left_button_link",
        "label": "Primary Button Link"
      }, {
        "type": "text",
        "id": "right_button_text",
        "label": "Secondary Button Label"
      }, {
        "type": "url",
        "id": "right_button_link",
        "label": "Secondary Button Link"
      }, {
        "type": "color",
        "id": "overlay_color",
        "label": "Overlay Color",
        "default": "#000000"
      }, {
        "type": "range",
        "id": "overlay_opacity",
        "label": "Overlay Opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "default": 20
      }
    ],
    "presets": [
      {
        "name": "Custom Page Hero"
      }
    ]
  }
{% endschema %}