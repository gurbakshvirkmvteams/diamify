        "min": 0,
        "max": 120,
        "step": 4,
        "unit": "px",
        "default": 60
      }, {
        "type": "range",
        "id": "padding_bottom",
        "label": "Bottom padding",
        "min": 0,
        "max": 120,
        "step": 4,
        "unit": "px",
        "default": 60
      }
    ],
    "presets": [
      {
        "name": "Banner With Collection"
      }
    ]
  }
