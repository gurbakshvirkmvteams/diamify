{% comment %} {{ 'custom-collection-showcase.css' | asset_url | stylesheet_tag }} {% endcomment %}
{% style %}
  .custom-collection-showcase {
    width: 100%;
  }
  /* Heading */
  .custom-showcase-tagline {
    margin: 0 0 12px;
    text-align: center;
    text-transform: uppercase;      
    letter-spacing: 2px;
    font-size: 12px;
  }

  .custom-showcase-heading {
    margin: 0 0 16px;
    text-align: center;
  }

  .custom-showcase-description {
    max-width: 700px;
    margin: 0 auto 50px;
    text-align: center;
  }

  /* Main Grid */
  .custom-showcase-grid {
    display: grid;
    grid-template-columns: var(--banner-width) 1fr;
    gap: var(--grid-gap);
    align-items: stretch;
  }

  .layout--left {
    grid-template-areas: "banner products";
  }

  .layout--right {
    grid-template-columns: 1fr var(--banner-width);
    grid-template-areas: "products banner";
  }

  .custom-showcase-banner {
    grid-area: banner;
  }

  .custom-showcase-products {
    grid-area: products;
  }

  /* Banner */
  .custom-showcase-banner {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    height: var(--banner-height);
  }

  .custom-showcase-banner picture,
  .custom-showcase-banner img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .custom-showcase-banner img {
    object-fit: cover;
  }

  /* Banner Content */
  .custom-showcase-banner-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    padding: 40px;
  }

  .banner-subheading {
    margin: 0 0 12px;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .banner-heading {
    margin: 0;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
  }

  .banner-text {
    margin-top: 14px;
  }

  .banner-button {
    display: inline-block;
    margin-top: 20px;
    text-decoration: underline;
  }

  /* Products */
  .custom-showcase-products {
    display: grid;
    gap: var(--grid-gap);
  }

  .columns-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .columns-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .columns-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  /* Product Card */
  .custom-product-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .custom-product-image {
    flex:1;
    min-height:0;
    overflow:hidden;
  }

  .custom-product-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    transition: 0.3s ease;
  }

  .custom-product-card:hover img {
    transform: scale(1.04);
  }

  .custom-product-info {
    padding: 18px 8px;
    text-align: center;
  }

  .custom-product-title {
    margin: 0 0 8px;
    font-size: 14px;
    line-height: 1.4;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .custom-product-price {
    display: block;
    font-size: 13px;
    color: #777;
  }
.custom-showcase-products{
    height:var(--banner-height);
}
.custom-showcase-products{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    grid-template-rows:repeat(2,1fr);
    gap:var(--grid-gap);
    height:var(--banner-height);
}
.custom-product-card{
    display:flex;
    flex-direction:column;
    height:100%;
    min-height:0;
}
  /* Responsive */
  @media screen and (max-width: 989px) {

    .custom-showcase-grid {
      grid-template-columns: 1fr;
      grid-template-areas: "banner" "products";
    }

    .custom-showcase-banner {
      height: 500px;
    }

    .custom-showcase-products {
      grid-template-columns: repeat(2, 1fr);
    }

    .custom-showcase-banner-overlay {
      padding: 30px;
    }
  }

  @media screen and (max-width: 749px) {

    .custom-showcase-banner {
      height: 400px;
    }

    .custom-showcase-products {
      grid-template-columns: 1fr;
    }

    .custom-showcase-banner-overlay {
      padding: 20px;
    }

    .banner-heading {
      font-size: 36px;
    }

  }
{% endstyle %}
<div class="custom-collection-showcase color-{{ section.settings.color_scheme }} gradient" style="
        background:{{ section.settings.background_color }};
        padding-top:{{ section.settings.padding_top }}px;
        padding-bottom:{{ section.settings.padding_bottom }}px;
    ">
  <div class="{% if section.settings.full_width %}custom-collection-showcase--full{% else %}page-width{% endif %}">

    {% if section.settings.tagline != blank %}
      <p class="custom-showcase-tagline">
        {{ section.settings.tagline }}
      </p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="custom-showcase-heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="custom-showcase-description rte">
        {{ section.settings.description }}
      </div>
    {% endif %}

    {% assign current_collection = section.settings.collection %}

      <div class="custom-showcase-grid layout--{{ section.settings.layout }}" style="
            --banner-width:{{ section.settings.banner_width }}%;
            --banner-height:{{ section.settings.banner_height }}px;
            --grid-gap:{{ section.settings.grid_gap }}px;
            --radius:{{ section.settings.banner_radius }}px;
        ">

      <!-- Banner -->

      <div class="custom-showcase-banner">

        {% if section.settings.banner_link != blank %}
          <a href="{{ section.settings.banner_link }}">
        {% endif %}

        {% if section.settings.banner_image != blank %}

          <picture>

            {% if section.settings.mobile_banner_image != blank %}
              <source media="(max-width:749px)" srcset="{{ section.settings.mobile_banner_image | image_url: width:900 }}">
            {% endif %}

            {{
              section.settings.banner_image | image_url: width: 1800 | image_tag: class: 'custom-showcase-banner-image', loading: 'lazy'
            }}

          </picture>

        {% else %}

          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}

        {% endif %}

        <div class="custom-showcase-banner-overlay" style="
                justify-content:
                {% case section.settings.content_vertical %}
                {% when 'top' %}flex-start
                {% when 'center' %}center
                {% else %}flex-end
                {% endcase %};

                align-items:
                {% case section.settings.content_horizontal %}
                {% when 'left' %}flex-start
                {% when 'center' %}center
                {% when 'right' %}flex-end
                {% endcase %};

                text-align:{{ section.settings.content_horizontal }};
            ">

          {% if section.settings.banner_subheading != blank %}
            <p class="banner-subheading" style="color:{{ section.settings.subheading_color }}">
              {{ section.settings.banner_subheading }}
            </p>
          {% endif %}

          {% if section.settings.banner_heading != blank %}
            <h3 class="banner-heading" style="color:{{ section.settings.heading_color }}">
              {{ section.settings.banner_heading }}
            </h3>
          {% endif %}

          {% if section.settings.banner_text != blank %}
            <div class="banner-text rte" style="color:{{ section.settings.text_color }}">
              {{ section.settings.banner_text }}
            </div>
          {% endif %}

          {% if section.settings.banner_button != blank %}
            <span class="banner-button" style="color:{{ section.settings.button_color }}">
              {{ section.settings.banner_button }}
            </span>
          {% endif %}

        </div>

        {% if section.settings.banner_link != blank %}
          </a>
        {% endif %}

      </div>

      <!-- Products -->

      <div class="custom-showcase-products columns-{{ section.settings.products_per_row }}">

        {% if current_collection != blank %}

          {% for product in current_collection.products limit: section.settings.products_to_show %}

            <a href="{{ product.url }}" class="custom-product-card">

              <div class="custom-product-image">

                {% if product.featured_image %}

                  {{
                    product.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: product.title
                  }}

                {% endif %}

              </div>

              <div class="custom-product-info">

                <h3 class="custom-product-title">
                  {{ product.title }}
                </h3>

                <span class="custom-product-price">
                  {{ product.price | money }}
                </span>

              </div>

            </a>

          {% endfor %}

        {% else %}

          <p>Please select a collection.</p>

        {% endif %}

      </div>

    </div>

  </div>
</div>
{% schema %}
  {
    "name": "Custom Collection",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "select",
        "id": "color_scheme",
        "options": [
          {
            "value": "accent-1",
            "label": "t:sections.all.colors.accent_1.label"
          },
          {
            "value": "accent-2",
            "label": "t:sections.all.colors.accent_2.label"
          },
          {
            "value": "background-1",
            "label": "t:sections.all.colors.background_1.label"
          },
          {
            "value": "background-2",
            "label": "t:sections.all.colors.background_2.label"
          }, {
            "value": "inverse",
            "label": "t:sections.all.colors.inverse.label"
          }
        ],
        "default": "background-1",
        "label": "t:sections.all.colors.label",
        "info": "t:sections.all.colors.has_cards_info"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background color",
        "default": "#ffffff"
      },
      {
        "type": "checkbox",
        "id": "full_width",
        "label": "Full width",
        "default": false
      },

      {
        "type": "text",
        "id": "tagline",
        "label": "Tagline"
      }, {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Collection Showcase"
      }, {
        "type": "select",
        "id": "content_vertical",
        "label": "Content vertical position",
        "default": "bottom",
        "options": [
          {
            "value": "top",
            "label": "Top"
          }, {
            "value": "center",
            "label": "Center"
          }, {
            "value": "bottom",
            "label": "Bottom"
          }
        ]
      }, {
        "type": "select",
        "id": "content_horizontal",
        "label": "Content horizontal position",
        "default": "left",
        "options": [
          {
            "value": "left",
            "label": "Left"
          }, {
            "value": "center",
            "label": "Center"
          }, {
            "value": "right",
            "label": "Right"
          }
        ]
      }, {
        "type": "color",
        "id": "subheading_color",
        "label": "Subheading color",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "heading_color",
        "label": "Heading color",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "text_color",
        "label": "Description color",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "button_color",
        "label": "Button color",
        "default": "#ffffff"
      }, {
        "type": "richtext",
        "id": "description",
        "label": "Description"
      }, {
        "type": "collection",
        "id": "collection",
        "label": "Collection"
      }, {
        "type": "range",
        "id": "products_to_show",
        "label": "Products to show",
        "min": 2,
        "max": 12,
        "step": 1,
        "default": 4
      }, {
        "type": "range",
        "id": "products_per_row",
        "label": "Products per row",
        "min": 2,
        "max": 4,
        "step": 1,
        "default": 2
      }, {
        "type": "select",
        "id": "layout",
        "label": "Layout",
        "default": "left",
        "options": [
          {
            "value": "left",
            "label": "Banner Left"
          }, {
            "value": "right",
            "label": "Banner Right"
          }
        ]
      }, {
        "type": "range",
        "id": "banner_width",
        "label": "Banner width (%)",
        "min": 20,
        "max": 70,
        "step": 5,
        "default": 40
      }, {
        "type": "range",
        "id": "grid_gap",
        "label": "Grid gap",
        "min": 0,
        "max": 60,
        "step": 4,
        "unit": "px",
        "default": 24
      }, {
        "type": "image_picker",
        "id": "banner_image",
        "label": "Desktop banner image"
      }, {
        "type": "image_picker",
        "id": "mobile_banner_image",
        "label": "Mobile banner image"
      }, {
        "type": "url",
        "id": "banner_link",
        "label": "Banner link"
      }, {
        "type": "range",
        "id": "banner_height",
        "label": "Banner height",
        "min": 300,
        "max": 900,
        "step": 20,
        "unit": "px",
        "default": 700
      }, {
        "type": "range",
        "id": "banner_radius",
        "label": "Banner border radius",
        "min": 0,
        "max": 40,
        "step": 2,
        "unit": "px",
        "default": 0
      }, {
        "type": "text",
        "id": "banner_subheading",
        "label": "Banner subheading"
      }, {
        "type": "text",
        "id": "banner_heading",
        "label": "Banner heading",
        "default": "Rings"
      }, {
        "type": "richtext",
        "id": "banner_text",
        "label": "Banner text"
      }, {
        "type": "text",
        "id": "banner_button",
        "label": "Button text",
        "default": "Shop all"
      }, {
        "type": "select",
        "id": "image_ratio",
        "label": "Product image ratio",
        "default": "square",
        "options": [
          {
            "value": "adapt",
            "label": "Adapt"
          }, {
            "value": "portrait",
            "label": "Portrait"
          }, {
            "value": "square",
            "label": "Square"
          }
        ]
      }, {
        "type": "checkbox",
        "id": "show_secondary_image",
        "label": "Show secondary image",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show vendor",
        "default": false
      }, {
        "type": "checkbox",
        "id": "show_rating",
        "label": "Show rating",
        "default": false
      }, {
        "type": "checkbox",
        "id": "enable_quick_add",
        "label": "Enable quick add",
        "default": false
      }, {
        "type": "checkbox",
        "id": "show_view_all",
        "label": "Show View all button",
        "default": true
      }, {
        "type": "text",
        "id": "view_all_text",
        "label": "View all button text",
        "default": "View all"
      }, {
        "type": "url",
        "id": "view_all_link",
        "label": "View all link"
      }, {
        "type": "range",
        "id": "padding_top",
