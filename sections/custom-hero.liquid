{{ 'custom.css' | asset_url | stylesheet_tag }}
<div class="custom-hero-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="custom-hero-content">
    <div class="hero-text">
      <h1>{{ section.settings.title }}</h1>

      <p>{{ section.settings.subtitle }}</p>

      <a href="{{ section.settings.button_link }}" class="hero-button">
        {{ section.settings.button_text }}
      </a>
    </div>

    <div class="hero-image">
      {% if section.settings.hero_image != blank %}
        {{
          section.settings.hero_image
          | image_url: width: 800
          | image_tag: loading: 'lazy'
        }}
      {% endif %}
    </div>
  </div>
</div>
{% schema %}
  {
    "name": "Hero Section",
    "disabled_on": {
    "groups": ["header", "footer"]
  },    
    "settings": [
      {
        "label": "Title",
        "type": "richtext",
        "id": "title"
      }, {
        "label": "Subtitle",
        "type": "text",
        "id": "subtitle"
      }, {
        "label": "Button Text",
        "type": "text",
        "id": "button_text"
      }, {
        "label": "Button Link",
        "type": "url",
        "id": "button_link"
      },
      {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 50
    }
    ],
    "presets": [
      {
        "name": "Hero Section"
      }
    ]
  }
{% endschema %}